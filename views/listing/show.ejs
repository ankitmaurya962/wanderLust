<% layout('layouts/boilerplate') -%>

<body>
  <div class="row" id="row">
    <div class="col-8 offset-2">
      <br />
      <h2><%=data.title%></h2>
      <br />
      <div class="card listing-card">
        <img src="<%=data.image%>" class="card-img-top show-img" alt="place_img" />
        <div class="card-body">
          <p class="card-text">
            <br />
            <%=data.desc%>
            <br />
            <%=data.location%>
            <br />
            <%=data.country%>
            <br />
            &#8377;<%=data.price.toLocaleString("en-IN")%>
          </p>
          <div class="button-container">
            <form action="/listing/<%=data._id%>/edit">
              <button class="btn btn-dark">Edit</button>
            </form>
            <form action="/listing/<%=data._id%>?_method=DELETE" method="post">
              <button class="btn btn-primary">Delete</button>
            </form>
          </div>
          <br>
          <hr>
          <h4>Leave a Review</h4>
          <form action="/listing/<%=data.id%>/reviews" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
              <label for="rating" class="form-label">Rating</label>
              <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-control" />
            </div>
            <div>
              <label for="comment" class="form-label">Comments</label>
              <textarea name="review[comments]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
              <div class="invalid-feedback">write a review</div>
            </div>
            <br>
            <button class="btn btn-outline-dark">Submit</button>
          </form>
          <hr>
          <h4>All Reviews</h4>
          <div class="row">
            <% for(let review of data.reviews){ %>
            <div class="card col-5 mb-3 ms-3">
              <div class="card-body">
                <h5 class="card-title">John doe</h5>
                <p class="card-text"><%=review.comments%></p>
                <p class="card-text"><%=review.rating%> stars</p>
              </div>
            </div>
            <%} %>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>