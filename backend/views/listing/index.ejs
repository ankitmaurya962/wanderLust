<% layout('layouts/boilerplate') -%>
<style>
  .filters {
    display: flex;
    align-items: center;
  }

  .filter {
    opacity: 0.7;
    text-align: center;
    margin-left: 2rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    text-decoration: none;
    color: inherit;
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer
  }

  .filter p {
    font-size: 0.8rem;
  }

  .switch-container {
    border: 1px solid black;
    display: flex;
    align-items: center;
    height: 2.5rem;
    border-radius: 1rem;
    margin-left: 4rem;
    padding: 0.5rem;
  }

  .tax-display {
    display: none;
  }
</style>

<div class="filters">

  <a href="/listing?category=trending" class="filter">
    <i class="fa-solid fa-fire"></i>
    <p>Trending</p>
  </a>

  <a href="/listing?category=rooms" class="filter">
    <i class="fa-solid fa-bed"></i>
    <p>Rooms</p>
  </a>

  <a href="/listing?category=iconic" class="filter">
    <i class="fa-solid fa-city"></i>
    <p>Iconic Cities</p>
  </a>

  <a href="/listing?category=mountains" class="filter">
    <i class="fa-solid fa-mountain"></i>
    <p>Mountains</p>
  </a>

  <a href="/listing?category=castles" class="filter">
    <i class="fa-brands fa-fort-awesome"></i>
    <p>Castles</p>
  </a>

  <a href="/listing?category=forest" class="filter">
    <i class="fa-solid fa-tree"></i>
    <p>Forest</p>
  </a>

  <a href="/listing?category=pools" class="filter">
    <i class="fa-solid fa-person-swimming"></i>
    <p>Pools</p>
  </a>

  <a href="/listing?category=camping" class="filter">
    <i class="fa-solid fa-campground"></i>
    <p>Camping</p>
  </a>

  <a href="/listing?category=farms" class="filter">
    <i class="fa-solid fa-cow"></i>
    <p>Farms</p>
  </a>

  <a href="/listing?category=arctic" class="filter">
    <i class="fa-solid fa-snowflake"></i>
    <p>Arctic</p>
  </a>

  <a href="/listing?category=boat" class="filter">
    <i class="fa-solid fa-sailboat"></i>
    <p>Boat</p>
  </a>

  <a href="/listing?category=spiritual" class="filter">
    <i class="fa-solid fa-om"></i>
    <p>Spiritual</p>
  </a>

  <a href="/listing?category=desert" class="filter">
    <i class="fa-solid fa-mound"></i>
    <p>Desert</p>
  </a>

  <div class="switch-container">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Include GST</label>
    </div>
  </div>
</div>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1" id="cards">
  <%if(AllList.length == 0){%>
  <h1>Coming soon</h1>
  <%} else {%>
  <% for(let list of AllList){ %>

  <div class="col" class="card">
    <a href="/listing/<%= list._id %>" style="text-decoration: none;">

      <div class="card">
        <img src="<%= list.image.url.replace('/upload', '/upload/q_auto:low,w_400,h_250,c_fill') %>" class="card-img-top" style="height:20rem; object-fit:cover;">

        <div class="card-img-overlay"></div>

        <div class="card-body">
          <h5 class="card-title"><%= list.title %></h5>

          <p class="card-text">
            &#8377;<%= list.price.toLocaleString("en-IN") %>/night
            <i class="tax-display">&nbsp; &nbsp; +18% GST</i>
          </p>
        </div>

      </div>

    </a>
  </div>
  <% } %>
  <% } %>

</div>

<script>
  const switchCheckDefault = document.getElementById('switchCheckDefault');
  const taxdisplay = document.querySelectorAll('.tax-display');
  switchCheckDefault.addEventListener('change', function() {
    if (this.checked) {
      for (let tax of taxdisplay) {
        tax.style.display = 'inline';
      }
    } else {
      for (let tax of taxdisplay) {
        tax.style.display = 'none';
      }
    }
  });
</script>