<% layout('layouts/boilerplate') -%>
<body>
  <div class="row" id="row">
    <div class="col-8 offset-2">
      <br />
      <h2>Add a new Hotel</h2>
      <br />
      <form
        method="post"
        action="/listing"
        class="needs-validation"
        novalidate
        enctype="multipart/form-data"
      >
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input
            type="text"
            name="title"
            placeholder="title"
            required
            id="title"
            class="form-control"
          />
        </div>
        <div class="mb-3">
          <label for="desc" class="form-label">Description of Place</label>
          <textarea
            name="desc"
            rows="5"
            cols="20"
            placeholder="Enter description"
            id="desc"
            class="form-control"
          ></textarea>
        </div>
        <div class="mb-3">
          <label for="image" class="form-label">Upload Image</label>
          <input
            type="file"
            name="image"
            placeholder="image"
            id="image"
            class="form-control"
          />
        </div>
        <div class="mb-3">
          <label for="category" class="form-label">Category</label>

          <select name="category" class="form-select" required>
            <option value="">Select Category</option>
            <option value="trending">Trending</option>
            <option value="rooms">Rooms</option>
            <option value="iconic">Iconic Cities</option>
            <option value="mountains">Mountains</option>
            <option value="castles">Castles</option>
            <option value="pools">Pools</option>
            <option value="camping">Camping</option>
            <option value="farms">Farms</option>
            <option value="forest">Forest</option>
            <option value="arctic">Arctic</option>
            <option value="boat">Boat</option>
            <option value="spiritual">Spiritual</option>
            <option value="desert">Desert</option>
          </select>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="price" class="form-label">Enter Price</label>
            <input
              name="price"
              placeholder="price"
              required
              id="price"
              class="form-control"
            />
          </div>
          <div class="col-md-6 mb-3">
            <label for="country" class="form-label">Enter Country</label>
            <input
              type="text"
              name="country"
              placeholder="country"
              required
              class="form-control"
            />
          </div>
        </div>
        <div class="mb-3">
          <label for="location" class="form-label">Enter Location</label>
          <input
            type="text"
            name="location"
            placeholder="location"
            required
            id="location"
            class="form-control"
          />
        </div>
        <div class="mb-3">
          <button class="btn btn-dark">Submit</button>
        </div>
      </form>
    </div>
  </div>
</body>
